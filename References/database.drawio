        <mxCell id="aLCn89Acz7aisRa-XQr1-4" parent="aLCn89Acz7aisRa-XQr1-3" style="text;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=12;whiteSpace=wrap;html=1;" value="&lt;div&gt;CREATE TABLE news (&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; id&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; BIGINT PRIMARY KEY AUTO_INCREMENT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; author_id&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;BIGINT NOT NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- Người đăng tin (Admin/Staff)&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; title&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;VARCHAR(255) NOT NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- Tiêu đề tin tức&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; summary&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;TEXT NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- Tóm tắt ngắn để hiển thị ở trang danh sách&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; thumbnail_url&amp;nbsp; &amp;nbsp;VARCHAR(255) NOT NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- Ảnh minh họa lấy từ bài gốc&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; original_url&amp;nbsp; &amp;nbsp; VARCHAR(500) NOT NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- Link dẫn thẳng tới bài báo gốc (Rất quan trọng)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; source_name&amp;nbsp; &amp;nbsp; &amp;nbsp;VARCHAR(100) NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- Tên nguồn (Ví dụ: Báo Đà Nẵng, VnExpress...)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; category&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ENUM(&#39;MARKET&#39;, &#39;GUIDE&#39;, &#39;LAW&#39;, &#39;PROJECT&#39;) DEFAULT &#39;MARKET&#39;, -- Phân loại&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; created_at&amp;nbsp; &amp;nbsp; &amp;nbsp; TIMESTAMP DEFAULT CURRENT_TIMESTAMP, --&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; updated_at&amp;nbsp; &amp;nbsp; &amp;nbsp; TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP, --&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; CONSTRAINT fk_news_author FOREIGN KEY (author_id) REFERENCES users(id) ON DELETE CASCADE --&amp;nbsp;&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;" vertex="1">
