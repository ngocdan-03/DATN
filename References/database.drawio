        <mxCell id="4hm3wUvxWXILRWCaB5DD-31" parent="4hm3wUvxWXILRWCaB5DD-30" style="text;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=12;whiteSpace=wrap;html=1;" value="&lt;div&gt;CREATE TABLE transactions (&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; id&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; BIGINT PRIMARY KEY AUTO_INCREMENT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; user_id&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;BIGINT NOT NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- Liên kết tới bảng users(id)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; post_id&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;BIGINT NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- Liên kết tới bảng posts(id), để NULL nếu là nạp tiền&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; amount&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; DECIMAL(15, 2) NOT NULL,&amp;nbsp; &amp;nbsp; -- Số tiền biến động (Ví dụ: 100000.00 hoặc -20000.00)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; balance_before&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; DECIMAL(15, 2) NOT NULL,&amp;nbsp; &amp;nbsp; -- Số dư TRƯỚC khi thực hiện giao dịch (để đối soát lỗi)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; balance_after&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;DECIMAL(15, 2) NOT NULL,&amp;nbsp; &amp;nbsp; -- Số dư SAU khi thực hiện giao dịch&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; transaction_type&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ENUM(&#39;DEPOSIT&#39;, &#39;PAYMENT&#39;, &#39;REFUND&#39;) NOT NULL, -- Loại: Nạp tiền, Thanh toán, Hoàn tiền&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; payment_method&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; VARCHAR(20) DEFAULT &#39;SYSTEM&#39;, -- Phương thức: &#39;PAYPAL&#39;, &#39;MOMO&#39;, &#39;CASH&#39;, &#39;SYSTEM&#39;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; status&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ENUM(&#39;PENDING&#39;, &#39;SUCCESS&#39;, &#39;CANCELLED&#39;, &#39;FAILED&#39;) DEFAULT &#39;PENDING&#39;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; paypal_order_id&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;VARCHAR(100) NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- Lưu ID của PayPal để kiểm tra lại nếu bị lỗi&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; description&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;TEXT,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;-- Ghi chú: &quot;Nạp tiền qua PayPal&quot;, &quot;Thanh toán tin đăng #123&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; created_at&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; TIMESTAMP DEFAULT CURRENT_TIMESTAMP,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; updated_at&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; CONSTRAINT fk_user FOREIGN KEY (user_id) REFERENCES users(id),&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; CONSTRAINT fk_post FOREIGN KEY (post_id) REFERENCES posts(id) ON DELETE SET NULL&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;" vertex="1">
