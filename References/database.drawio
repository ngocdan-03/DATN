        <mxCell id="4hm3wUvxWXILRWCaB5DD-14" parent="4hm3wUvxWXILRWCaB5DD-13" style="text;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=12;whiteSpace=wrap;html=1;" value="&lt;div&gt;CREATE TABLE users (&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; id&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; BIGINT PRIMARY KEY AUTO_INCREMENT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; email&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;VARCHAR(255) NOT NULL UNIQUE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; password&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; VARCHAR(255) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; full_name&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;VARCHAR(100) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; phone&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;VARCHAR(15) NOT NULL UNIQUE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; gender&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; TINYINT(1) DEFAULT 0,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- 0: Unknown, 1: Male, 2: Female&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; birthday&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; DATE NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;-- Lưu ngày sinh thay vì tuổi&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; address&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;VARCHAR(255) NULL,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;-- Địa chỉ thường trú&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; avatar_url&amp;nbsp; &amp;nbsp; &amp;nbsp; VARCHAR(255) DEFAULT &#39;default.png&#39;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; balance&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;DECIMAL(15,2) DEFAULT 0 NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; is_verified&amp;nbsp; &amp;nbsp; &amp;nbsp;BOOLEAN DEFAULT FALSE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; is_locked&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;BOOLEAN DEFAULT FALSE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; created_at&amp;nbsp; &amp;nbsp; &amp;nbsp; TIMESTAMP DEFAULT CURRENT_TIMESTAMP,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; updated_at&amp;nbsp; &amp;nbsp; &amp;nbsp; TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;" vertex="1">
